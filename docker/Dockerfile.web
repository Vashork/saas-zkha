FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends -o DEBIAN_FRONTEND=noninteractive curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/
COPY init_db.py .

RUN useradd -m -u 1000 zhkh-bot && \
    mkdir -p /app/data/uploads /var/log/zhkh-bot && \
    chown -R zhkh-bot:zhkh-bot /app /var/log/zhkh-bot

USER zhkh-bot

CMD ["sh", "-c", "python init_db.py && uvicorn app.web.main:app --host 0.0.0.0 --port 8000"]
