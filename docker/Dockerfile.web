FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends -o DEBIAN_FRONTEND=noninteractive curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/
COPY alembic.ini ./alembic.ini
COPY alembic/ ./alembic/
COPY init_db.py .
COPY docker/start-web.sh ./docker/start-web.sh

CMD ["sh", "./docker/start-web.sh"]
